{%- comment -%}
  Product Card Snippet
  Displays a product with hover effect, variant options, and inventory tracking
{%- endcomment -%}

<div class="product-card" data-product-id="{{ product.id }}">
  <div class="product-card__image-wrapper">
    <a href="{{ product.url }}" class="product-card__link">
      {%- if product.featured_image -%}
        {%- assign first_image = product.featured_image -%}
        {%- assign second_image = product.images[1] -%}
        
        <div class="product-card__image-container">
          <img 
            src="{{ first_image | img_url: '533x' }}" 
            alt="{{ first_image.alt | escape }}"
            class="product-card__image product-card__image--primary"
            loading="lazy"
            width="{{ first_image.width }}"
            height="{{ first_image.height }}"
          >
          
          {%- if second_image -%}
            <img 
              src="{{ second_image | img_url: '533x' }}" 
              alt="{{ second_image.alt | escape }}"
              class="product-card__image product-card__image--secondary"
              loading="lazy"
              width="{{ second_image.width }}"
              height="{{ second_image.height }}"
            >
          {%- endif -%}
        </div>
      {%- endif -%}
    </a>
    
    {%- if product.available == false -%}
      <div class="product-card__badge product-card__badge--sold-out">
        {{ 'products.product.sold_out' | t }}
      </div>
    {%- elsif product.compare_at_price > product.price -%}
      <div class="product-card__badge product-card__badge--sale">
        {{ 'products.product.on_sale' | t }}
      </div>
    {%- endif -%}
  </div>
  
  <div class="product-card__info">
    <h3 class="product-card__title">
      <a href="{{ product.url }}">{{ product.title }}</a>
    </h3>
    
    <div class="product-card__price">
      {%- if product.compare_at_price > product.price -%}
        <span class="product-card__price--compare">{{ product.compare_at_price | money }}</span>
        <span class="product-card__price--sale">{{ product.price | money }}</span>
      {%- else -%}
        <span class="product-card__price--regular">{{ product.price | money }}</span>
      {%- endif -%}
    </div>
    
    {%- if product.has_only_default_variant == false -%}
      <div class="product-card__variants">
        {%- for option in product.options_with_values -%}
          {%- if option.name == 'Color' -%}
            <div class="product-card__color-swatches">
              {%- for value in option.values -%}
                {%- assign variant = product.variants | where: option.name, value | first -%}
                {%- if variant -%}
                  <button 
                    type="button" 
                    class="product-card__color-swatch {% if variant.available == false %}product-card__color-swatch--unavailable{% endif %}"
                    style="background-color: {{ value | downcase | replace: ' ', '' }};"
                    data-variant-id="{{ variant.id }}"
                    title="{{ value }}"
                    aria-label="{{ value }}"
                  ></button>
                {%- endif -%}
              {%- endfor -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
    
    <div class="product-card__actions">
      {%- if product.available -%}
        <button 
          type="button" 
          class="product-card__add-to-cart btn btn--primary"
          data-product-id="{{ product.id }}"
          {% if product.has_only_default_variant %}
            data-variant-id="{{ product.first_available_variant.id }}"
          {% endif %}
        >
          {{ 'products.product.add_to_cart' | t }}
        </button>
      {%- else -%}
        <button 
          type="button" 
          class="product-card__add-to-cart btn btn--disabled" 
          disabled
        >
          {{ 'products.product.sold_out' | t }}
        </button>
      {%- endif -%}
      
      {%- if product.has_only_default_variant == false -%}
        <button 
          type="button" 
          class="product-card__quick-add"
          data-product-id="{{ product.id }}"
          aria-label="{{ 'products.product.quick_add' | t }}"
        >
          {% render 'icon-plus' %}
        </button>
      {%- endif -%}
    </div>
  </div>
</div>

{% render 'quick-add-drawer', product: product %}